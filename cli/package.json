{
  "name": "@nodalis/cli",
  "version": "1.0.0",
  "description": "Nodalis CLI — install, launch, configure MCP",
  "type": "module",
  "bin": { "nodalis": "dist/index.js" },
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "default": "./dist/lib/*.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "commander": "^12.0.0",
    "jsonc-parser": "^3.2.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  },
  "engines": { "node": ">=20.0.0" }
}
