{
  "typeId": "tech:database:cockroachdb",
  "label": "CockroachDB",
  "description": "Distributed SQL database with automatic sharding and multi-region survivability",
  "category": "database",
  "style": {
    "shape": "cylinder",
    "color": "#6933FF",
    "icon": "database"
  },
  "dataSchema": {
    "replicationFactor": {
      "type": "number",
