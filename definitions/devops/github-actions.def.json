{
  "typeId": "tech:devops:github-actions",
  "label": "GitHub Actions",
  "description": "CI/CD automation platform integrated with GitHub repositories",
  "category": "ci-cd",
  "style": {
    "shape": "rectangle",
    "color": "#24292E",
    "icon": "git-branch"
  },
  "constraints": {
    "maxOutputs": 10
  },
  "dataSchema": {
    "trigger": {
      "type": "string",
      "enum": ["push", "pr", "schedule", "manual"],
      "description": "Workflow trigger event"
    },
    "runners": {
      "type": "string",
      "enum": ["ubuntu", "windows", "macos"],
      "description": "Runner OS environment"
    }
  }
}
