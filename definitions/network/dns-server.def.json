  "description": "Resolves domain names to IP addresses via authoritative or recursive lookups",
  "category": "device",
  "style": {
    "shape": "rectangle",
    "color": "#1E40AF",
    "icon": "compass"
  },
  "dataSchema": {
    "role": {
      "type": "string",
