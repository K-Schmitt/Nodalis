{
  "id": "web",
  "label": "Web Application",
  "description": "Full web stack — frontend, API, backend frameworks, auth, databases, monitoring.",
  "include": ["general", "web", "backend", "database", "auth", "monitoring", "storage"],
  "rules": {
    "forbiddenConnections": [
      {
        "from": "frontend",
        "to": "database",
        "reason": "Frontend must not query the database directly — route through a backend or API layer"
      },
      {
        "from": "mobile",
        "to": "database",
        "reason": "Mobile clients must go through a backend API, not the database directly"
      }
    ],
    "requiredTypes": ["auth"],
    "forbiddenTypes": [
      "tech:game:game-loop", "tech:game:physics", "tech:game:entity",
      "tech:game:scene", "tech:game:input", "tech:game:audio",
      "tech:game:network", "tech:game:leaderboard", "tech:game:matchmaking"
    ],
    "maxNodesPerType": {
      "tech:general:load-balancer": 2,
      "tech:auth:auth0": 1,
      "tech:auth:keycloak": 1
    },
    "noCycles": true,
    "defaultMaxInputs": 20,
    "defaultMaxOutputs": 20
  }
}
