{
  "name": "nodalis",
  "displayName": "Nodalis",
  "description": "Agnostic semantic-graph meta-modeler — graph, versioning, MCP.",
  "version": "0.1.5",
  "publisher": "Nodalis",
  "license": "MIT",
  "icon": "media/icon.png",
  "engines": { "vscode": "^1.80.0" },
  "main": "./dist/extension.js",
  "activationEvents": ["onStartupFinished"],
  "categories": ["Visualization", "Other"],
  "keywords": ["graph", "meta-model", "architecture", "mcp", "versioning"],
  "repository": { "type": "git", "url": "https://github.com/K-Schmitt/Nodalis.git", "directory": "extension" },
  "bugs": { "url": "https://github.com/K-Schmitt/Nodalis/issues" },
  "homepage": "https://github.com/K-Schmitt/Nodalis#readme",
  "galleryBanner": { "color": "#1E1B4B", "theme": "dark" },
  "contributes": {
    "commands": [
      { "command": "archi-os.open", "title": "Nodalis: Open", "icon": "$(link-external)" },
      { "command": "archi-os.start", "title": "Nodalis: Start Runtime", "icon": "$(play)" },
      { "command": "archi-os.stop", "title": "Nodalis: Stop Runtime", "icon": "$(debug-stop)" },
      { "command": "archi-os.configureMcp", "title": "Nodalis: Configure MCP" },
      { "command": "archi-os.createSnapshot", "title": "Nodalis: Create Snapshot" },
      { "command": "archi-os.refreshVersions", "title": "Nodalis: Refresh Versions", "icon": "$(refresh)" },
      { "command": "archi-os.restoreVersion", "title": "Nodalis: Restore Version" }
    ],
    "viewsContainers": {
      "activitybar": [
        { "id": "archi-os", "title": "Nodalis", "icon": "media/icon.svg" }
      ]
    },
    "views": {
      "archi-os": [
        { "id": "archi-os.versions", "name": "Versions" }
      ]
    },
    "viewsWelcome": [
      {
        "view": "archi-os.versions",
        "contents": "Nodalis runtime is stopped.\n[$(play) Start Runtime](command:archi-os.start)\n[$(link-external) Open Panel](command:archi-os.open)\nStart the runtime, then open the graph panel."
      }
    ],
    "menus": {
      "view/title": [
        { "command": "archi-os.start", "when": "view == archi-os.versions", "group": "navigation@1" },
        { "command": "archi-os.open", "when": "view == archi-os.versions", "group": "navigation@2" },
        { "command": "archi-os.stop", "when": "view == archi-os.versions", "group": "navigation@3" },
        { "command": "archi-os.createSnapshot", "when": "view == archi-os.versions", "group": "navigation@4" },
        { "command": "archi-os.refreshVersions", "when": "view == archi-os.versions", "group": "navigation@5" }
      ]
    },
    "configuration": {
      "title": "Nodalis",
      "properties": {
        "archiOs.autostart": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start the Nodalis runtime when a workspace with .archi/ is opened."
        },
        "archiOs.autoBootstrap": {
          "type": "boolean",
          "default": true,
          "description": "On first open of a workspace, automatically configure MCP, start the runtime, and open the panel (runs once per workspace)."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "vsce package --no-dependencies",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@archi-os/cli": "*",
    "@archi-os/core": "*",
    "jsonc-parser": "^3.2.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  }
}
